#!/bin/sh
# $EDITOR wrapper for nvim-unception.
#
# Must stay a single space-free token: Claude Code spawns $EDITOR without a
# shell, splitting it on spaces, so flags/quotes in $EDITOR itself get mangled
# into bogus filename arguments. The name keeps "nvim" as a word so callers
# that sniff $EDITOR still detect a terminal editor and pass +LINE.
exec nvim \
    --cmd 'let g:unception_block_while_host_edits=1' \
    --cmd 'let g:unception_open_buffer_in_new_tab=0' \
    "$@"
